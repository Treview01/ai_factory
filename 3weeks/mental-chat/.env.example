# ========================================
# Mental Chat - 환경 변수 템플릿
# ========================================
# 사용법:
#   1. 이 파일을 .env로 복사:  cp .env.example .env
#   2. 아래 값들을 실제 값으로 교체
#   3. .env 파일은 git에 커밋하지 마세요 (.gitignore에 등록됨)

# OpenAI API Key
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# 서버 포트 (기본값: 3001)
PORT=3001
